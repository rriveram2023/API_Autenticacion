AUTH_API_HOST=0.0.0.0
AUTH_API_PORT=8001
IDENTITY_HEADER=X-Authenticated-User
IDENTITY_EMAIL_HEADER=X-Authenticated-Email
IDENTITY_GROUPS_HEADER=X-Authenticated-Groups
IDENTITY_DISPLAY_NAME_HEADER=X-Authenticated-Display-Name
MFA_POLICY_HEADER=X-Auth-Mfa-Policy
NGINX_PUBLIC_HOST=e3display.com
NGINX_PUBLIC_SCHEME=https
ENTRA_TENANT_ID=<tenant-id>
OAUTH2_PROXY_REDIRECT_URL=https://e3display.com/auth/callback
OAUTH2_PROXY_CLIENT_ID=<client-id>
OAUTH2_PROXY_CLIENT_SECRET=<client-secret>
OAUTH2_PROXY_COOKIE_SECRET=<cookie-secret-ascii-32-chars>
OAUTH2_PROXY_EMAIL_DOMAIN=*
OAUTH2_PROXY_COOKIE_SECURE=true
OAUTH2_PROXY_SESSION_COOKIE_MINIMAL=true
OAUTH2_PROXY_WHITELIST_DOMAINS=e3display.com
AD_DOMAIN=E3.LAN
AD_SHORT_DOMAIN=E3
AD_SERVER=E3.LAN
AD_SEARCH_BASE=DC=E3,DC=LAN
AD_BIND_USER=
AD_BIND_PASSWORD=
TLS_CERT_PATH=/run/certs/fullchain.crt
TLS_KEY_PATH=/run/certs/private.key

